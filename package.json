{
  "name": "my-extension",
  "displayName": "My Extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "main": "./src/focus_status.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Inactivity Reminder",
      "properties": {
        "inactivityReminder.telegramId": {
          "type": "string",
          "default": "",
          "markdownDescription": "Enter your Telegram ID (optional). Example: `@username`"
        }
      }
    }
  }
}
