{
  "name": "badgerbadger",
  "displayName": "BadgerBadger",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.70.0"
  },
  "main": "./src/focus_status.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "publisher": "GraysonPlug",
  "contributes": {
    "configuration": {
      "title": "Badger Extension",
      "properties": {
        "inactivityReminder.telegramId": {
          "type": "string",
          "default": "",
          "markdownDescription": "Enter your Telegram ID (optional). Example: `@username`"
        },
        "inactivityReminder.notificationInterval": {
          "type": "number",
          "default": 300,
          "minimum": 1,
          "markdownDescription": "Interval between inactivity notifications in seconds. Default is 300 seconds (5 minutes)."
        }
      }
    }
  }
}
